{
  "name": "undersea-blaster",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main/index.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "npm run build:electron && electron . --inspect",
    "build": "vite build",
    "build:electron": "./scripts/build-electron.sh",
    "build:all": "npm run build && npm run build:electron",
    "electron": "electron .",
    "start": "npm run build:all && npm run electron",
    "preview": "vite preview --port 5173",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:install": "playwright install --with-deps",
    "package:linux": "npm run build:all && electron-builder --linux",
    "package:win": "npm run build:all && electron-builder --win",
    "package:mac": "npm run build:all && electron-builder --mac"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/node": "^24.2.1",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "jsdom": "^26.1.0",
    "typescript": "^5.5.4",
    "vite": "^5.3.4",
    "vite-plugin-pwa": "^1.0.2",
    "vitest": "^2.0.5"
  }
}
